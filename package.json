{
  "name": "latex-to-mathtype",
  "version": "1.0.0",
  "description": "Convert LaTeX equations in .docx to native Word (OMML) format",
  "main": "dist/main.js",
  "scripts": {
    "build": "node build.mjs",
    "dev": "concurrently \"node build.mjs --watch\" \"electronmon dist/main.js\"",
    "start": "electron dist/main.js",
    "electron": "node_modules/.pnpm/electron@41.2.0/node_modules/electron/dist/electron.exe dist/main.js",
    "cli": "node dist/cli.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.15.0",
  "devDependencies": {
    "@types/node": "^25.6.0",
    "concurrently": "^9.2.1",
    "electron": "^41.2.0",
    "electronmon": "^2.0.4",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  },
  "dependencies": {
    "fast-xml-parser": "^5.6.0",
    "katex": "^0.16.45",
    "yauzl": "^3.3.0",
    "yazl": "^3.3.1"
  }
}
